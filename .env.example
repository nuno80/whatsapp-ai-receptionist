# Core
# LLM provider for chat responses:
#   anthropic (default) → uses ANTHROPIC_API_KEY, model claude-3-5-sonnet-20241022
#   nvidia             → uses NVIDIA_API_KEY, OpenAI-compatible endpoint at LLM_BASE_URL
LLM_PROVIDER=anthropic
# Override the model for either provider (defaults: anthropic=claude-3-5-sonnet-20241022, nvidia=z-ai/glm-5.2)
# LLM_MODEL=
# Only used when LLM_PROVIDER != anthropic. Defaults to NVIDIA's public NIM endpoint.
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
NVIDIA_API_KEY=nvapi-your-nvidia-key-here
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_APP_SECRET=your-app-secret
REDIS_URL=redis://localhost:6379

# Booking (optional — only if modules.booking is true)
GOOGLE_SERVICE_ACCOUNT_JSON=base64-encoded-service-account-json
GOOGLE_CALENDAR_ID=your-google-calendar-id
GOOGLE_CALENDAR_OWNER_EMAIL=your-calendar-email@gmail.com

# Payments (optional — only if modules.payments is true)
STRIPE_API_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Internal
INTERNAL_SECRET=your-internal-secret
